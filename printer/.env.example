# ─────────────────────────────────────────────────────────────────────────────
# Qopy Printer Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server (REQUIRED) ─────────────────────────────────────────────────────────
# WebSocket endpoint for the Qopy cloud server
QOPY_SERVER_WS=ws://your-server.com/ws/device

# HTTP base URL used for file downloads
QOPY_SERVER_HTTP=http://your-server.com

# ── Device Identity (REQUIRED) ────────────────────────────────────────────────
# Unique ID for this kiosk/printer device
QOPY_DEVICE_ID=PI_KIOSK_001

# Secret API key — must match what the server expects
QOPY_API_KEY=your_secret_api_key_here

# ── Simulation Mode ───────────────────────────────────────────────────────────
# Set to 1 to skip real printing (useful for testing on non-Pi machines)
QOPY_SIMULATE=0

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# How often (in seconds) to send a HEARTBEAT to the server
QOPY_HEARTBEAT_INTERVAL=30

# ── Reconnection ──────────────────────────────────────────────────────────────
# Base delay in seconds for exponential backoff reconnect
QOPY_RECONNECT_BASE=3

# Maximum reconnect delay in seconds
QOPY_RECONNECT_MAX=30

# ── File Limits ───────────────────────────────────────────────────────────────
# Maximum file size in MB — jobs larger than this are rejected before download
QOPY_MAX_FILE_SIZE_MB=20

# Where to save downloaded files temporarily (deleted after printing)
QOPY_DOWNLOAD_DIR=/tmp/qopy_downloads

# ── Job Queue ─────────────────────────────────────────────────────────────────
# Maximum number of jobs allowed in the queue at once (rate limiting)
QOPY_MAX_QUEUE_SIZE=10

# ── Persistence ───────────────────────────────────────────────────────────────
# SQLite database path — queue survives Pi reboots
QOPY_DB_PATH=/var/lib/qopy/jobs.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Log file path (rotating, 5 MB × 3 backups)
QOPY_LOG_FILE=/var/log/qopy-printer.log

# Log level: DEBUG | INFO | WARNING | ERROR
QOPY_LOG_LEVEL=INFO

# ── Timeouts ──────────────────────────────────────────────────────────────────
# Seconds to wait for JOB_DETAILS response from server
QOPY_JOB_DETAILS_TIMEOUT=10

# Max seconds to wait for a print job to complete in CUPS
QOPY_PRINT_TIMEOUT=300
