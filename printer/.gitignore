# ─────────────────────────────────────────────────────────────────────────────
# Qopy Printer Agent — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment / secrets ─────────────────────────────────────────────────────
# Never commit real credentials
.env
*.env

# ── SQLite database ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
jobs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Downloaded print files (temp) ─────────────────────────────────────────────
downloads/
/tmp/

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Test / coverage ───────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

tests/